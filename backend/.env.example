# ── Database ──
# Supabase connection pooled URL (Transaction Mode, e.g. port 6543)
DATABASE_URL=postgresql://postgres.bnlnuetzqhvpdlchmeoy:[YOUR-PASSWORD]@aws-0-[YOUR-REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
# Supabase direct connection URL (Session Mode, e.g. port 5432)
DIRECT_URL=postgresql://postgres.bnlnuetzqhvpdlchmeoy:[YOUR-PASSWORD]@aws-0-[YOUR-REGION].pooler.supabase.com:5432/postgres

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379

# ── JWT ──
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=24h

# ── Azure Communication Services ──
AZURE_COMMUNICATION_CONNECTION_STRING=endpoint=https://your-resource.communication.azure.com/;accesskey=your-access-key
AZURE_COMMUNICATION_FROM_EMAIL=donotreply@yourdomain.com

# ── SMTP Fallback ──
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password

# ── App ──
FRONTEND_URL=http://localhost:5173
APP_PORT=3000

# ── Email Rate Limiting ──
EMAIL_INDIVIDUAL_DELAY_MS=10000
EMAIL_BATCH_SIZE=5
EMAIL_BATCH_DELAY_MS=15000

